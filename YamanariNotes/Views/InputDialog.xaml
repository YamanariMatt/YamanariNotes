<Window x:Class="YamanariNotes.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entrada"
        Height="170"
        Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptTextBlock" TextWrapping="Wrap" />
        <TextBox x:Name="ValueTextBox" Grid.Row="1" Margin="0,12,0,0" />

        <StackPanel Grid.Row="2" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="80" Margin="0,0,8,0" Content="OK" IsDefault="True" Click="Ok_Click" />
            <Button Width="80" Content="Cancelar" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
